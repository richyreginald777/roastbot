# ─────────────────────────────────────────────────────────────────────────────
# RoastBot — Environment Variables
# Copy these into your ~/.zshrc (or equivalent shell profile) and fill in the
# real values. The bot reads everything from the shell environment — no .env
# file is used at runtime (mirrors receipt-agent behaviour).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Slack ───────────────────────────────────────────────────────────────────
# Bot token (xoxb-...) from your Slack app's "OAuth & Permissions" page.
# Required bot scopes: app_mentions:read, channels:history, chat:write, users:read
# Required event subscriptions: app_mention, message.channels
export ROASTBOT_SLACK_BOT_TOKEN=xoxb-
# App-level token (xapp-...) for Socket Mode — "Basic Information" → "App-Level Tokens"
export ROASTBOT_SLACK_APP_TOKEN=xapp-

# The bot's own Slack user ID (e.g. U07XXXXXXXX) — used to strip @mentions
# and to ignore the bot's own messages
export ROASTBOT_BOT_USER_ID=U08L93Z798T

# ─── Gemini ──────────────────────────────────────────────────────────────────
export GEMINI_API_KEY=iduybh332909ei32-0
# Additional keys, rotated automatically on rate limits.
# NOTE: quotas are per Google Cloud PROJECT — extra keys only add throughput
# if they belong to DIFFERENT projects.
# export GEMINI_API_KEY_2=your-second-key-here
# export GEMINI_API_KEY_3=your-third-key-here
# Fallback chains (comma-separated, tried in order on rate limit / error).
# These are the defaults — override only to change the order or models.
# NOTE: ROASTBOT_GEMINI_MODEL / ROASTBOT_GEMINI_IMAGE_MODEL are no longer used.
# export ROASTBOT_GEMINI_TEXT_MODELS=gemini-3.5-flash,gemini-3-flash-preview,gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
# export ROASTBOT_GEMINI_IMAGE_MODELS=gemini-3.1-flash-lite-image,gemini-3.1-flash-image,gemini-2.5-flash-image

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# OPTION A (Supabase): set DATABASE_URL and skip the rest.
# Use the SESSION POOLER connection string from Supabase (Connect → Session pooler)
# — the direct connection is IPv6-only and unreachable from most hosts.
# SSL is auto-enabled for remote URLs (override with ROASTBOT_DB_SSL=true/false).
# export DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# OPTION B (local): discrete vars
export ROASTBOT_DB_HOST=localhost                     # optional, default: localhost
export ROASTBOT_DB_PORT=5432                          # optional, default: 5430
export ROASTBOT_DB_USER=postgres                      # optional, default: postgres
export ROASTBOT_DB_PASSWORD=
export ROASTBOT_DB_NAME=roastbot                      # optional, default: roastbot

# ─── Behaviour ───────────────────────────────────────────────────────────────
# Minimum minutes between UNSOLICITED roasts per channel (mentions/threads
# always get a reply — this only throttles jump-ins on regular messages)
export ROASTBOT_COOLDOWN_MINUTES=10                   # optional, default: 10

# How many recent channel messages to keep as conversational context
export ROASTBOT_CHANNEL_HISTORY_LIMIT=5              # optional, default: 5

# ─── Memes ───────────────────────────────────────────────────────────────────
# Meme image generation requires Slack bot scope: files:write
# (image model fallback chain is configured in the Gemini section above)
# Chance that any given reply becomes a meme (0.1 = ~1 in 10)
export ROASTBOT_MEME_PROBABILITY=0.1                  # optional, default: 0.1
# Minimum minutes between spontaneous memes per channel
export ROASTBOT_MEME_COOLDOWN_MINUTES=30              # optional, default: 30

export LOG_LEVEL=info                                 # optional, default: info
